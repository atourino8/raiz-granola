---
import Layout from '../layouts/Layout.astro';

const sent = Astro.url.searchParams.get('sent');
---

<Layout title="Recuperar contraseña">
  <section class="mx-auto max-w-md px-5 py-16">
    <div class="rounded-organic border border-avena/50 bg-white/70 p-8 shadow-suave">
      <h1 class="font-serif text-3xl font-semibold text-tierra">Recuperar contraseña</h1>
      <p class="mt-2 text-sm text-tierra/70">
        Escribe tu email y te enviaremos un enlace para crear una nueva contraseña.
      </p>

      {
        sent ? (
          <p class="mt-6 rounded-lg bg-musgo/15 px-4 py-3 text-sm text-bosque">
            Si ese email tiene una cuenta, te hemos enviado un enlace. Revisa tu bandeja
            (y la carpeta de spam).
          </p>
        ) : (
          <form method="POST" action="/api/auth/forgot" class="mt-6 space-y-4">
            <div>
              <label class="text-sm font-semibold text-tierra" for="email">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="mt-1 w-full rounded-xl border border-avena/70 bg-crema px-4 py-3 focus:border-miel focus:outline-none"
              />
            </div>
            <button class="w-full rounded-full bg-bosque px-6 py-3.5 font-semibold text-crema transition hover:bg-musgo">
              Enviar enlace
            </button>
          </form>
        )
      }

      <p class="mt-6 text-center text-sm text-tierra/70">
        <a href="/login" class="font-semibold text-miel hover:text-terracota">Volver a entrar</a>
      </p>
    </div>
  </section>
</Layout>
