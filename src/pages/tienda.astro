---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getActiveProducts } from '../lib/catalog';
import { getSetting } from '../lib/settings';

const products = await getActiveProducts();
const titulo = await getSetting('tienda_title');
const subtitulo = await getSetting('tienda_subtitle');
---

<Layout title="Tienda">
  <section class="mx-auto max-w-6xl px-5 py-14">
    <div class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-miel">La tienda</span>
      <h1 class="mt-2 font-serif text-4xl font-semibold text-tierra md:text-5xl">{titulo}</h1>
      <p class="mt-3 text-lg text-tierra/70">{subtitulo}</p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((p) => <ProductCard product={p} />)}
    </div>
  </section>
</Layout>
