---
import Layout from '../layouts/Layout.astro';
import { consumeToken } from '../lib/tokens';
import { setEmailVerified } from '../lib/auth';

const token = Astro.url.searchParams.get('token') ?? '';
let ok = false;
if (token) {
  const userId = await consumeToken(token, 'verify');
  if (userId) {
    await setEmailVerified(userId);
    ok = true;
  }
}
---

<Layout title="Verificar email — Raíz Granola">
  <section class="mx-auto max-w-md px-5 py-20 text-center">
    {
      ok && (
        <div>
          <div class="text-6xl">✅</div>
          <h1 class="mt-4 font-serif text-3xl font-semibold text-tierra">¡Email verificado!</h1>
          <p class="mt-3 text-tierra/70">Tu cuenta ya está activa. Ya puedes entrar.</p>
          <a href="/login" class="mt-6 inline-block rounded-full bg-bosque px-7 py-3.5 font-semibold text-crema hover:bg-musgo">
            Entrar
          </a>
        </div>
      )
    }
    {
      !ok && (
        <div>
          <div class="text-6xl">⚠️</div>
          <h1 class="mt-4 font-serif text-3xl font-semibold text-tierra">Enlace no válido</h1>
          <p class="mt-3 text-tierra/70">El enlace de verificación no es válido o ha caducado. Entra en tu cuenta y pide uno nuevo.</p>
          <a href="/cuenta" class="mt-6 inline-block rounded-full border border-bosque/30 px-7 py-3.5 font-semibold text-bosque hover:bg-bosque/10">
            Ir a mi cuenta
          </a>
        </div>
      )
    }
  </section>
</Layout>
