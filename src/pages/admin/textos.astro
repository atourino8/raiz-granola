---
import Layout from '../../layouts/Layout.astro';
import { isVerifiedAdmin } from '../../lib/admin';
import { getAllSettings, settingLabels, settingGroups } from '../../lib/settings';
import AdminImageField from '../../components/AdminImageField.astro';
import BlockOrderField from '../../components/BlockOrderField.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login?next=' + encodeURIComponent(Astro.url.pathname));
if (!isVerifiedAdmin(user)) return Astro.redirect('/');

const settings = await getAllSettings();
const saved = Astro.url.searchParams.get('saved');
const field =
  'mt-1 w-full rounded-xl border border-avena/70 bg-crema px-4 py-2.5 focus:border-miel focus:outline-none';
---

<Layout title="Textos — Admin">
  <section class="mx-auto max-w-3xl px-5 py-12">
    <div class="flex items-center justify-between">
      <h1 class="font-serif text-3xl font-semibold text-tierra">Textos e imágenes de la web</h1>
      <a href="/admin" class="text-sm font-semibold text-tierra/60 hover:text-miel">← Panel</a>
    </div>

    <p class="mt-3 rounded-xl border border-avena/60 bg-arena/50 px-4 py-3 text-sm text-tierra/75">
      Edita cualquier texto o foto de la web. En las imágenes puedes <strong>subir un archivo</strong> desde tu
      ordenador o pegar un enlace. Recuerda: <strong>nada se publica hasta que pulsas «Guardar» al final</strong>.
    </p>

    {saved && (
      <p class="mt-4 rounded-lg bg-musgo/15 px-4 py-2 text-sm text-bosque">✓ Cambios guardados y publicados.</p>
    )}

    <form method="POST" action="/api/admin/settings" class="mt-6 space-y-10 pb-24">
      {
        settingGroups.map((group) => (
          <div>
            <h2 class="font-serif text-xl font-semibold text-tierra">{group.title}</h2>
            <div class="mt-4 space-y-4">
              {group.keys.map((k) =>
                k === 'home_block_order' ? (
                  <BlockOrderField value={settings[k]} />
                ) : k.endsWith('_image') || k === 'brand_favicon' ? (
                  <AdminImageField name={k} label={settingLabels[k]} value={settings[k]} />
                ) : (
                  <div>
                    <label class="text-sm font-semibold text-tierra">{settingLabels[k]}</label>
                    <textarea name={k} rows="2" class={field}>{settings[k]}</textarea>
                  </div>
                ),
              )}
            </div>
          </div>
        ))
      }

      <div class="sticky bottom-0 -mx-5 mt-6 border-t border-avena/60 bg-crema/95 px-5 py-4 backdrop-blur">
        <button class="w-full rounded-full bg-bosque px-8 py-3.5 font-semibold text-crema shadow-suave transition hover:bg-musgo sm:w-auto">
          Guardar y publicar
        </button>
        <span class="ml-3 text-sm text-tierra/60">Aplica todos los cambios de esta página.</span>
      </div>
    </form>
  </section>
</Layout>
