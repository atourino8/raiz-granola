---
import Layout from '../layouts/Layout.astro';
import HeroBlock from '../components/home/HeroBlock.astro';
import ValoresBlock from '../components/home/ValoresBlock.astro';
import FavoritasBlock from '../components/home/FavoritasBlock.astro';
import HistoriaBlock from '../components/home/HistoriaBlock.astro';
import { getFeaturedProducts } from '../lib/catalog';
import { getAllSettings } from '../lib/settings';

const featured = await getFeaturedProducts();
const s = await getAllSettings();

const blocks: Record<string, any> = {
  hero: HeroBlock,
  valores: ValoresBlock,
  favoritas: FavoritasBlock,
  historia: HistoriaBlock,
};

// Orden configurable; añade al final los bloques que falten por si el ajuste está incompleto.
const requested = (s.home_block_order || '').split(',').map((x) => x.trim()).filter(Boolean);
const order = requested.filter((id) => id in blocks);
for (const id of Object.keys(blocks)) if (!order.includes(id)) order.push(id);
---

<Layout>
  {
    order.map((id) => {
      const Block = blocks[id];
      return <Block s={s} featured={featured} />;
    })
  }
</Layout>
