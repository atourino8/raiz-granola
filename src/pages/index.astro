---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getFeaturedProducts } from '../lib/catalog';
import { getSetting } from '../lib/settings';

const featured = await getFeaturedProducts();
const heroSubtitle = await getSetting('home_hero_subtitle');
const storyText = await getSetting('home_story_text');

const valores = [
  { icon: '🌱', title: 'Ingredientes ecológicos', text: 'Avena de cultivo ecológico y frutos secos de proximidad, sin aditivos ni conservantes.' },
  { icon: '🔥', title: 'Horneada a fuego lento', text: 'En pequeños lotes en nuestro obrador, para conseguir ese punto crujiente y dorado.' },
  { icon: '🍯', title: 'Sin azúcares refinados', text: 'Endulzada solo con miel cruda, sirope de dátil o la fruta. Dulzor honesto.' },
  { icon: '📦', title: 'Embalaje compostable', text: 'Bolsas y cajas 100% compostables. Rico para ti, amable con la tierra.' },
];
---

<Layout>
  <section class="grain relative overflow-hidden">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-16 md:grid-cols-2 md:py-24">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full bg-bosque/10 px-4 py-1.5 text-sm font-semibold text-bosque">
          🌾 Obrador artesanal · Lotes pequeños
        </span>
        <h1 class="mt-5 font-serif text-4xl font-semibold leading-tight text-tierra md:text-6xl">
          Granola horneada<br /><span class="text-miel">a fuego lento</span>
        </h1>
        <p class="mt-5 max-w-md text-lg leading-relaxed text-tierra/75">{heroSubtitle}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/tienda"
            class="rounded-full bg-bosque px-7 py-3.5 font-semibold text-crema shadow-suave transition hover:bg-musgo"
          >
            Ver la tienda
          </a>
          <a
            href="/producto/caja-degustacion"
            class="rounded-full border border-bosque/30 px-7 py-3.5 font-semibold text-bosque transition hover:bg-bosque/10"
          >
            Probar la caja degustación
          </a>
        </div>
        <div class="mt-8 flex items-center gap-6 text-sm text-tierra/60">
          <span>⭐ 4,9/5 · +2.400 desayunos</span>
          <span>🚚 Envío 24-48 h</span>
        </div>
      </div>

      <div class="relative">
        <div class="mx-auto flex aspect-square max-w-md items-center justify-center rounded-organic bg-gradient-to-br from-avena via-arena to-miel/40 shadow-suave">
          <span class="text-[10rem] drop-shadow">🥣</span>
        </div>
        <div class="absolute -bottom-4 -left-2 rotate-[-6deg] rounded-2xl bg-white/90 px-4 py-3 text-sm font-semibold text-bosque shadow-suave">
          100% ecológica 🌱
        </div>
        <div class="absolute -right-2 top-6 rotate-[8deg] rounded-2xl bg-white/90 px-4 py-3 text-sm font-semibold text-terracota shadow-suave">
          Sin azúcar refinado
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-8">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        valores.map((v) => (
          <div class="rounded-organic border border-avena/50 bg-white/60 p-6">
            <div class="text-3xl">{v.icon}</div>
            <h3 class="mt-3 font-serif text-lg font-semibold text-tierra">{v.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-tierra/70">{v.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="font-serif text-3xl font-semibold text-tierra md:text-4xl">Nuestras favoritas</h2>
        <p class="mt-2 text-tierra/70">Las recetas que más repiten en casa.</p>
      </div>
      <a href="/tienda" class="hidden text-sm font-semibold text-miel hover:text-terracota sm:block">
        Ver todas →
      </a>
    </div>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((p) => <ProductCard product={p} />)}
    </div>
  </section>

  <section class="grain relative overflow-hidden bg-bosque text-crema">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-16 md:grid-cols-2">
      <div class="flex aspect-video items-center justify-center rounded-organic bg-musgo/40">
        <span class="text-8xl">👩‍🍳</span>
      </div>
      <div>
        <h2 class="font-serif text-3xl font-semibold md:text-4xl">Empezó en una cocina pequeña</h2>
        <p class="mt-4 leading-relaxed text-crema/80">{storyText}</p>
        <a
          href="/nosotros"
          class="mt-6 inline-block rounded-full bg-miel px-6 py-3 font-semibold text-tierra transition hover:bg-crema"
        >
          Conoce nuestra historia
        </a>
      </div>
    </div>
  </section>
</Layout>
