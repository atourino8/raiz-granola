---
import Layout from '../layouts/Layout.astro';
import { getAllSettings } from '../lib/settings';

const s = await getAllSettings();
const pasos = [
  { n: '01', t: s.nosotros_paso1_title, d: s.nosotros_paso1_text },
  { n: '02', t: s.nosotros_paso2_title, d: s.nosotros_paso2_text },
  { n: '03', t: s.nosotros_paso3_title, d: s.nosotros_paso3_text },
  { n: '04', t: s.nosotros_paso4_title, d: s.nosotros_paso4_text },
];
---

<Layout title="Nuestra historia">
  <section class="grain relative overflow-hidden">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <span class="text-sm font-semibold uppercase tracking-wide text-miel">Nuestra historia</span>
      <h1 class="mt-3 font-serif text-4xl font-semibold text-tierra md:text-5xl">{s.nosotros_title}</h1>
      <p class="mt-5 text-lg leading-relaxed text-tierra/75">{s.nosotros_intro}</p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-5 py-8">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        pasos.map((p) => (
          <div class="rounded-organic border border-avena/50 bg-white/60 p-6">
            <span class="font-serif text-3xl font-semibold text-avena">{p.n}</span>
            <h3 class="mt-2 font-serif text-lg font-semibold text-tierra">{p.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-tierra/70">{p.d}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-5 py-16">
    <div class="grid items-center gap-10 rounded-organic bg-arena/60 p-10 md:grid-cols-2">
      <div class="flex aspect-square items-center justify-center overflow-hidden rounded-organic bg-gradient-to-br from-avena to-miel/40">
        {
          s.nosotros_compromiso_image ? (
            <img src={s.nosotros_compromiso_image} alt="Nuestro compromiso" class="h-full w-full object-cover" />
          ) : (
            <span class="text-9xl">🌾</span>
          )
        }
      </div>
      <div>
        <h2 class="font-serif text-3xl font-semibold text-tierra">{s.nosotros_compromiso_title}</h2>
        <p class="mt-4 leading-relaxed text-tierra/75">{s.nosotros_compromiso_text}</p>
        <a
          href="/tienda"
          class="mt-6 inline-block rounded-full bg-bosque px-7 py-3.5 font-semibold text-crema transition hover:bg-musgo"
        >
          Probar nuestras granolas
        </a>
      </div>
    </div>
  </section>
</Layout>
