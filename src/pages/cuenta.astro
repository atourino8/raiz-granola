---
import Layout from '../layouts/Layout.astro';
import { db, ensureSchema } from '../lib/db';
import { formatPrice } from '../lib/products';
import { getAllProductsAdmin } from '../lib/catalog';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

await ensureSchema();
const res = await db.execute({
  sql: `SELECT id, amount_total, status, items_json, created_at
        FROM orders WHERE user_id = ? ORDER BY created_at DESC LIMIT 20`,
  args: [user.id],
});

const products = await getAllProductsAdmin();
const bySlug: Record<string, { name: string; emoji: string }> = {};
for (const p of products) bySlug[p.slug] = { name: p.name, emoji: p.emoji };

const orders = res.rows.map((r) => ({
  id: Number(r.id),
  total: Number(r.amount_total),
  status: String(r.status),
  date: String(r.created_at),
  items: JSON.parse(String(r.items_json)) as Array<{ slug: string; qty: number }>,
}));

const statusLabel: Record<string, string> = {
  pending: 'Pendiente de pago',
  paid: 'Pagado',
  fulfilled: 'Enviado',
  cancelled: 'Cancelado',
};

const bienvenida = Astro.url.searchParams.get('bienvenida');
const reenviado = Astro.url.searchParams.get('reenviado');
---

<Layout title="Mi cuenta — Raíz Granola">
  <section class="mx-auto max-w-4xl px-5 py-14">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="font-serif text-4xl font-semibold text-tierra">Hola, {user.name.split(' ')[0]} 👋</h1>
        <p class="mt-1 text-tierra/70">{user.email}</p>
      </div>
      <form method="POST" action="/api/auth/logout">
        <button class="rounded-full border border-bosque/30 px-5 py-2.5 text-sm font-semibold text-bosque transition hover:bg-bosque/10">
          Cerrar sesión
        </button>
      </form>
    </div>

    {reenviado && <p class="mt-6 rounded-lg bg-musgo/15 px-4 py-3 text-sm text-bosque">Te hemos reenviado el email de verificación.</p>}

    {
      !user.emailVerified && (
        <div class="mt-6 flex flex-wrap items-center justify-between gap-3 rounded-organic border border-miel/40 bg-miel/10 p-5">
          <div>
            <p class="font-semibold text-tierra">Verifica tu email</p>
            <p class="text-sm text-tierra/70">
              {bienvenida ? '¡Bienvenida! ' : ''}Te hemos enviado un enlace a {user.email}. Confírmalo para activar todo.
            </p>
          </div>
          <form method="POST" action="/api/auth/resend">
            <button class="rounded-full bg-bosque px-5 py-2.5 text-sm font-semibold text-crema hover:bg-musgo">
              Reenviar email
            </button>
          </form>
        </div>
      )
    }

    <h2 class="mt-12 font-serif text-2xl font-semibold text-tierra">Tus pedidos</h2>

    {
      orders.length === 0 ? (
        <div class="mt-6 rounded-organic border border-avena/50 bg-white/60 p-10 text-center">
          <p class="text-tierra/70">Todavía no tienes pedidos.</p>
          <a href="/tienda" class="mt-4 inline-block rounded-full bg-miel px-6 py-3 font-semibold text-tierra hover:bg-terracota hover:text-crema">
            Descubre nuestras granolas
          </a>
        </div>
      ) : (
        <div class="mt-6 space-y-4">
          {orders.map((o) => (
            <div class="rounded-2xl border border-avena/50 bg-white/70 p-5">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <div>
                  <p class="font-serif font-semibold text-tierra">Pedido #{o.id}</p>
                  <p class="text-sm text-tierra/60">{new Date(o.date).toLocaleDateString('es-ES')}</p>
                </div>
                <span class="rounded-full bg-bosque/10 px-3 py-1 text-xs font-semibold text-bosque">
                  {statusLabel[o.status] ?? o.status}
                </span>
              </div>
              <div class="mt-3 flex flex-wrap gap-3 text-sm text-tierra/70">
                {o.items.map((it) => (
                  <span>
                    {bySlug[it.slug]?.emoji ?? '🌾'} {bySlug[it.slug]?.name ?? it.slug} × {it.qty}
                  </span>
                ))}
              </div>
              <p class="mt-3 font-semibold text-bosque">{formatPrice(o.total)}</p>
            </div>
          ))}
        </div>
      )
    }

    <div class="mt-16 rounded-organic border border-terracota/30 bg-terracota/5 p-6">
      <h2 class="font-serif text-xl font-semibold text-tierra">Tus datos</h2>
      <p class="mt-2 text-sm text-tierra/70">
        Puedes descargar una copia de tus datos o eliminar tu cuenta de forma permanente.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href="/api/account/export"
          class="rounded-full border border-bosque/30 px-5 py-2.5 text-sm font-semibold text-bosque transition hover:bg-bosque/10"
        >
          Descargar mis datos
        </a>
        <form
          method="POST"
          action="/api/account/delete"
          data-confirm="¿Seguro que quieres eliminar tu cuenta? Esta acción no se puede deshacer."
        >
          <button class="rounded-full border border-terracota/50 px-5 py-2.5 text-sm font-semibold text-terracota transition hover:bg-terracota hover:text-crema">
            Eliminar mi cuenta
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('form[data-confirm]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      if (!confirm(form.getAttribute('data-confirm') || '¿Seguro?')) e.preventDefault();
    });
  });
</script>
