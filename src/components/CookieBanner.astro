---
// Aviso de cookies (solo informativo: únicamente usamos cookies necesarias).
// Visible por defecto SIN depender de JS; el script lo oculta si ya se aceptó.
---

<div id="cookie-banner" class="fixed inset-x-0 bottom-0 z-50">
  <div class="mx-auto my-4 max-w-3xl rounded-organic border border-avena/60 bg-crema/95 p-5 shadow-suave backdrop-blur">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-tierra/80">
        Usamos solo cookies necesarias para que la tienda funcione — sin publicidad ni analítica.
        Más información en la
        <a href="/cookies" class="font-semibold text-miel hover:text-terracota">Política de Cookies</a>.
      </p>
      <button
        data-accept
        class="shrink-0 rounded-full bg-bosque px-6 py-2.5 text-sm font-semibold text-crema transition hover:bg-musgo"
      >
        Entendido
      </button>
    </div>
  </div>
</div>

<script>
  const KEY = 'raiz_cookie_consent';
  const banner = document.getElementById('cookie-banner');
  try {
    if (banner && localStorage.getItem(KEY)) banner.remove();
  } catch {
    /* localStorage no disponible: el banner simplemente queda visible */
  }
  banner?.querySelector('[data-accept]')?.addEventListener('click', () => {
    try {
      localStorage.setItem(KEY, '1');
    } catch {
      /* no-op */
    }
    banner.remove();
  });
</script>
