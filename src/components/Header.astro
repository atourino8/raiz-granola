---
import { isVerifiedAdmin } from '../lib/admin';

interface Props {
  user: { id: number; name: string; email: string } | null;
}
const { user } = Astro.props;
const admin = isVerifiedAdmin(user);
const path = Astro.url.pathname;
const links = [
  { href: '/tienda', label: 'Tienda' },
  { href: '/nosotros', label: 'Nuestra historia' },
];
---

<header class="sticky top-0 z-40 border-b border-avena/40 bg-crema/85 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4">
    <a href="/" class="flex items-center gap-2 font-serif text-xl font-semibold text-bosque">
      <span class="text-2xl">🌾</span>
      <span>Raíz<span class="text-miel">Granola</span></span>
    </a>

    <ul class="hidden items-center gap-7 text-sm font-semibold md:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                'transition-colors hover:text-miel',
                path.startsWith(l.href) ? 'text-miel' : 'text-tierra/80',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }
      {
        admin && (
          <li>
            <a
              href="/admin"
              class:list={[
                'transition-colors hover:text-miel',
                path.startsWith('/admin') ? 'text-miel' : 'text-tierra/80',
              ]}
            >
              Admin
            </a>
          </li>
        )
      }
    </ul>

    <div class="flex items-center gap-3">
      {
        user ? (
          <a
            href="/cuenta"
            class="hidden rounded-full border border-bosque/30 px-4 py-2 text-sm font-semibold text-bosque transition hover:bg-bosque/10 sm:inline-block"
          >
            Hola, {user.name.split(' ')[0]}
          </a>
        ) : (
          <a
            href="/login"
            class="hidden text-sm font-semibold text-tierra/80 transition hover:text-miel sm:inline-block"
          >
            Entrar
          </a>
        )
      }
      <a
        href="/carrito"
        class="relative inline-flex items-center gap-2 rounded-full bg-bosque px-4 py-2 text-sm font-semibold text-crema shadow-suave transition hover:bg-musgo"
      >
        <span>Cesta</span>
        <span
          id="cart-badge"
          class="inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-miel px-1 text-xs font-bold text-tierra"
          data-cart-count
          hidden>0</span
        >
      </a>
    </div>
  </nav>
</header>

<script>
  import { cartCount } from '../lib/cart';
  const badge = document.querySelector('[data-cart-count]') as HTMLElement | null;
  if (badge) {
    cartCount.subscribe((n) => {
      badge.textContent = String(n);
      badge.hidden = n === 0;
    });
  }
</script>
