---
import ProductCard from '../ProductCard.astro';
import type { Product } from '../../lib/products';
interface Props { s: Record<string, string>; featured: Product[]; }
const { s, featured } = Astro.props;
---
<section class="mx-auto max-w-6xl px-5 py-16">
  <div class="flex items-end justify-between">
    <div>
      <h2 class="font-serif text-3xl font-semibold text-tierra md:text-4xl">{s.home_fav_title}</h2>
      <p class="mt-2 text-tierra/70">{s.home_fav_subtitle}</p>
    </div>
    <a href="/tienda" class="hidden text-sm font-semibold text-miel hover:text-terracota sm:block">
      Ver todas →
    </a>
  </div>
  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {featured.map((p) => <ProductCard product={p} />)}
  </div>
</section>
