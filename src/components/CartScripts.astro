---
// Comportamiento global del carrito: enlaza cualquier botón [data-add]
// y muestra un pequeño aviso al añadir. Se incluye una vez en el Layout.
---

<div
  id="toast"
  class="pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 translate-y-4 rounded-full bg-bosque px-5 py-3 text-sm font-semibold text-crema opacity-0 shadow-suave transition-all"
>
</div>

<script>
  import { addToCart } from '../lib/cart';

  const toast = document.getElementById('toast');
  let timer: ReturnType<typeof setTimeout>;

  function showToast(msg: string) {
    if (!toast) return;
    toast.textContent = msg;
    toast.style.opacity = '1';
    toast.style.transform = 'translate(-50%, 0)';
    clearTimeout(timer);
    timer = setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translate(-50%, 1rem)';
    }, 1800);
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement)?.closest('[data-add]') as HTMLElement | null;
    if (!btn) return;
    const qtyInput = document.querySelector<HTMLInputElement>('[data-qty-input]');
    const qty = qtyInput ? Math.max(1, parseInt(qtyInput.value || '1', 10)) : 1;
    addToCart(
      {
        slug: btn.dataset.slug!,
        name: btn.dataset.name!,
        price: Number(btn.dataset.price),
        emoji: btn.dataset.emoji || '🌾',
      },
      qty,
    );
    showToast(`${btn.dataset.name} añadida a la cesta`);
  });
</script>
