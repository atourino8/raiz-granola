---
// Mini-carrito lateral: se abre al añadir un producto o al pulsar "Cesta".
---
<div id="cart-drawer" class="fixed inset-0 z-[60] hidden">
  <div data-overlay class="absolute inset-0 bg-tierra/40"></div>
  <aside class="absolute right-0 top-0 flex h-full w-full max-w-sm translate-x-full flex-col bg-crema shadow-suave transition-transform duration-300 will-change-transform" data-panel>
    <div class="flex items-center justify-between border-b border-avena/50 px-5 py-4">
      <h2 class="font-serif text-xl font-semibold text-tierra">Tu cesta</h2>
      <button data-close class="rounded-full p-1 text-tierra/60 hover:bg-avena/40" aria-label="Cerrar">✕</button>
    </div>

    <div data-free class="border-b border-avena/40 bg-arena/40 px-5 py-3 text-sm text-tierra/80"></div>

    <div id="drawer-items" class="flex-1 space-y-3 overflow-y-auto px-5 py-4"></div>
    <div id="drawer-empty" class="hidden flex-1 flex-col items-center justify-center gap-3 px-5 text-center">
      <div class="text-5xl">🥣</div>
      <p class="text-tierra/70">Tu cesta está vacía.</p>
    </div>

    <div class="border-t border-avena/50 p-5">
      <div class="flex justify-between font-serif text-lg font-semibold text-bosque">
        <span>Total</span><span data-total>—</span>
      </div>
      <a href="/carrito" class="mt-4 block rounded-full border border-bosque/30 px-6 py-2.5 text-center text-sm font-semibold text-bosque hover:bg-bosque/10">
        Ver la cesta
      </a>
      <button data-checkout class="mt-2 w-full rounded-full bg-miel px-6 py-3 font-bold text-tierra transition hover:bg-terracota hover:text-crema disabled:opacity-60">
        Ir a pagar
      </button>
      <p data-err class="mt-2 hidden text-sm text-terracota"></p>
    </div>
  </aside>
</div>

<script>
  import { cart, cartItems, cartTotal, setQty, removeFromCart } from '../lib/cart';
  import { formatPrice } from '../lib/products';

  const FREE_SHIPPING = 3500; // céntimos (35 €)
  const drawer = document.getElementById('cart-drawer');
  if (drawer) {
    const panel = drawer.querySelector('[data-panel]') as HTMLElement;
    const itemsEl = document.getElementById('drawer-items')!;
    const emptyEl = document.getElementById('drawer-empty')!;
    const totalEl = drawer.querySelector('[data-total]') as HTMLElement;
    const freeEl = drawer.querySelector('[data-free]') as HTMLElement;
    const errEl = drawer.querySelector('[data-err]') as HTMLElement;

    const open = () => {
      drawer.classList.remove('hidden');
      // Forzamos un reflow para que la transición arranque desde translate-x-full
      // (evita el salto/lag al abrir).
      void panel.offsetWidth;
      panel.classList.remove('translate-x-full');
    };
    const close = () => {
      panel.classList.add('translate-x-full');
      setTimeout(() => drawer.classList.add('hidden'), 300);
    };

    drawer.querySelector('[data-overlay]')?.addEventListener('click', close);
    drawer.querySelector('[data-close]')?.addEventListener('click', close);
    document.addEventListener('raiz:cart-open', open);
    document.querySelectorAll('[data-open-cart]').forEach((el) =>
      el.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      }),
    );

    function render() {
      const items = cartItems();
      const total = cartTotal.get();
      totalEl.textContent = formatPrice(total);

      if (total >= FREE_SHIPPING) {
        freeEl.innerHTML = '¡Tienes <strong>envío gratis</strong>! 🎉';
      } else {
        const falta = FREE_SHIPPING - total;
        const pct = Math.min(100, Math.round((total / FREE_SHIPPING) * 100));
        freeEl.innerHTML =
          `Te faltan <strong>${formatPrice(falta)}</strong> para el envío gratis` +
          `<span class="mt-2 block h-2 w-full overflow-hidden rounded-full bg-avena/60">` +
          `<span class="block h-full rounded-full bg-miel" style="width:${pct}%"></span></span>`;
      }

      if (items.length === 0) {
        itemsEl.classList.add('hidden');
        emptyEl.classList.remove('hidden');
        emptyEl.classList.add('flex');
        return;
      }
      itemsEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');
      emptyEl.classList.remove('flex');

      itemsEl.innerHTML = items
        .map(
          (it) => `
        <div class="flex items-center gap-3 rounded-2xl border border-avena/50 bg-white/70 p-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-arena text-2xl">${it.emoji}</div>
          <div class="flex-1">
            <p class="text-sm font-semibold text-tierra">${it.name}</p>
            <p class="text-xs text-tierra/60">${formatPrice(it.price)}</p>
          </div>
          <div class="flex items-center rounded-full border border-avena/70 text-sm">
            <button class="px-2 text-tierra/70 hover:text-miel" data-dec="${it.slug}">−</button>
            <span class="w-6 text-center font-semibold">${it.qty}</span>
            <button class="px-2 text-tierra/70 hover:text-miel" data-inc="${it.slug}">+</button>
          </div>
          <button class="text-tierra/40 hover:text-terracota" data-del="${it.slug}" aria-label="Eliminar">✕</button>
        </div>`,
        )
        .join('');
    }

    itemsEl.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      const inc = t.getAttribute('data-inc');
      const dec = t.getAttribute('data-dec');
      const del = t.getAttribute('data-del');
      const items = cartItems();
      if (inc) setQty(inc, (items.find((i) => i.slug === inc)?.qty ?? 1) + 1);
      if (dec) setQty(dec, (items.find((i) => i.slug === dec)?.qty ?? 1) - 1);
      if (del) removeFromCart(del);
    });

    cart.subscribe(render);

    const checkoutBtn = drawer.querySelector('[data-checkout]') as HTMLButtonElement;
    checkoutBtn?.addEventListener('click', async () => {
      if (cartItems().length === 0) return;
      checkoutBtn.disabled = true;
      checkoutBtn.textContent = 'Redirigiendo…';
      errEl.classList.add('hidden');
      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: cartItems() }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'No se pudo iniciar el pago');
        window.location.href = data.url;
      } catch (err) {
        errEl.textContent = err instanceof Error ? err.message : 'Error inesperado';
        errEl.classList.remove('hidden');
        checkoutBtn.disabled = false;
        checkoutBtn.textContent = 'Ir a pagar';
      }
    });
  }
</script>
