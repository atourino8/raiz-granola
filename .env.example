# ─────────────────────────────────────────────
#  Variables de entorno — copia este archivo a .env
# ─────────────────────────────────────────────

# Base de datos libSQL / SQLite local (no requiere instalación)
# Para desarrollo se usa un archivo local:
DATABASE_URL="file:./data/raiz.db"
# En producción puedes usar Turso: libsql://tu-base.turso.io
# DATABASE_AUTH_TOKEN="..."

# Clave para firmar cookies de sesión (genera una aleatoria larga)
SESSION_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria"

# ─── Stripe ───
# Consíguelas en https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxx"
# Opcional: firma de webhooks (para /api/webhook)
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxx"

# URL pública del sitio (para redirecciones de Stripe)
PUBLIC_SITE_URL="http://localhost:4321"
